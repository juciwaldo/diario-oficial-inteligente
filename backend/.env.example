# ─────────────────────────────────────────────────────────────
# .env.example — Copie para .env e preencha os valores
# ─────────────────────────────────────────────────────────────

# BANCO DE DADOS (Supabase ou PostgreSQL local)
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/diario_inteligente

# AUTENTICAÇÃO (gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=sua_chave_secreta_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OPENAI (para resumo por IA — opcional)
OPENAI_API_KEY=sk-...

# TELEGRAM (preenchido pelo usuário nas configurações)
# Deixar vazio — usuário configura no painel

# AMBIENTE
ENVIRONMENT=development
